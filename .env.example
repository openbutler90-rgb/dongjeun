# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional but strongly recommended for accurate Korea place coordinates.
# Kakao Developers > JavaScript key, with the web domain registered.
VITE_KAKAO_MAP_KEY="YOUR_KAKAO_JAVASCRIPT_KEY"

# Optional server-side place/photo enrichment.
# Kakao REST API key improves address and coordinate verification in local/Electron server.
KAKAO_REST_API_KEY="YOUR_KAKAO_REST_API_KEY"

# Naver Search API keys improve real image lookup before fallback scraping.
NAVER_CLIENT_ID="YOUR_NAVER_CLIENT_ID"
NAVER_CLIENT_SECRET="YOUR_NAVER_CLIENT_SECRET"

# ==========================================
# 동전커피 앱 설정 (Anti-Hardcoding)
# ==========================================

# Admin email for privileged operations (Firestore Rules, auto-promotion).
VITE_ADMIN_EMAIL="your-admin-email@example.com"

# Hosted app URL for share links, notifications, and redirects.
VITE_APP_URL="https://your-app-url.web.app"

# OneSignal App ID for push notifications.
VITE_ONESIGNAL_APP_ID="your-onesignal-app-id"

# External community links displayed on homepage.
VITE_KAKAO_OPENCHAT="https://open.kakao.com/o/YOUR_CODE"
VITE_DISCORD_URL="https://discord.com/channels/YOUR_CHANNEL"
VITE_INSTAGRAM_URL="https://www.instagram.com/YOUR_ACCOUNT/"
