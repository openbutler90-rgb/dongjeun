{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "nickname": { "type": "string" },
        "email": { "type": "string" },
        "profileColor": { "type": "string" },
        "bio": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "role": { "type": "string", "enum": ["user", "manager", "admin"] },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["nickname", "email", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in a specific channel",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "locationName": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["channelId", "authorId", "title", "content"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["postId", "authorId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores posts in various channels"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments nested under posts"
    }
  }
}
