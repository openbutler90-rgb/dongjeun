rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 기본: 모두 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // 게시물 이미지 (posts/)
    match /posts/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 모임 이미지 (meetings/)
    match /meetings/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 배너 이미지 (banners/)
    match /banners/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && (
                     request.auth.token.email == 'openbutler90@gmail.com' ||
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'manager']
                   )
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 프로필 이미지 (profiles/)
    match /profiles/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
